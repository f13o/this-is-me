---
import Base from "../layouts/Base.astro";
---

<Base title="Home">
  <div class="flex flex-col sm:flex-row gap-10 items-center sm:items-start">
    <div class="flex-1">
      <p class="font-mono text-sm mb-4"><a href="/" class="text-zinc-400 dark:text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">~/</a><span class="text-accent dark:text-accent-dark">about</span></p>
      <h1 class="text-2xl font-light font-heading text-zinc-900 dark:text-zinc-100 mb-4">Francisco Casado</h1>
      <p class="text-zinc-600 dark:text-zinc-300 leading-relaxed mb-3">
        Engineer, putting technology at people's service
      </p>
      <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-3">
        Currently leading security at Fintual
      </p>
      <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-3">
        Used to teach design and innovation at Universidad de Chile
      </p>
      <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed">
        Also maker, woodworker, fond of various crafts
      </p>
    </div>
  </div>


  </Base>
