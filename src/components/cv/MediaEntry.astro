---
interface Props {
  title: string;
  source: string;
  year: number;
  spotifyEmbedUrl: string;
}

const { title, source, year, spotifyEmbedUrl } = Astro.props;
---

<div class="mb-6 last:mb-0">
  <p class="text-sm text-zinc-800 dark:text-zinc-100 mb-2">
    {title} <span class="text-xs text-zinc-400 dark:text-zinc-500">— {source}, {year}</span>
  </p>
  <iframe
    src={spotifyEmbedUrl}
    width="100%"
    height="152"
    frameborder="0"
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    class="rounded-md"
  />
</div>
