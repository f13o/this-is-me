---
interface Props {
  degree: string;
  institution: string;
  year: number;
  thesis?: string;
  thesisLink?: string;
}

const { degree, institution, year, thesis, thesisLink } = Astro.props;
---

<div class="mb-4 last:mb-0">
  <h3 class="font-heading font-light text-zinc-800 dark:text-zinc-100">{degree}</h3>
  <div class="flex items-baseline gap-2">
    <span class="text-accent dark:text-accent-dark text-sm">{institution}</span>
    <span class="font-mono text-xs text-zinc-400 dark:text-zinc-500">{year}</span>
  </div>
  {thesis && (
    <div class="mt-3">
      <h3 class="font-heading font-light text-sm text-zinc-500 dark:text-zinc-400 mb-3">Thesis</h3>
      <p class="text-sm text-zinc-800 dark:text-zinc-100">
        {thesisLink ? <a href={thesisLink} class="underline underline-offset-2 decoration-zinc-300 dark:decoration-zinc-600 hover:decoration-accent dark:hover:decoration-accent-dark">{thesis}</a> : thesis}
      </p>
      <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-0.5">
        <em>Undergraduate Thesis</em> <span class="font-mono">{year}</span>
      </p>
    </div>
  )}
</div>
